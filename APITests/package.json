{
  "name": "fakewebshop-api-tests",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "allure:clean": "rimraf allure-results allure-report",
    "test": "cucumber-js --profile default",
    "test:cucumber": "cucumber-js --profile default",
    "test:allure": "npm run allure:clean && cucumber-js --profile allure",
    "report:allure:generate": "allure generate allure-results --clean -o allure-report",
    "report:allure:open": "allure open allure-report",
    "qase:check-env": "node ./scripts/require-qase-env.js",
    "test:cucumber:qase": "npm run allure:clean && npm run qase:check-env && cucumber-js --profile qase",
    "test:qase": "npm run test:cucumber:qase"
  },
  "overrides": {
    "qaseio": "2.0.2"
  },
  "devDependencies": {
    "@cucumber/cucumber": "^12.7.0",
    "@playwright/test": "^1.54.2",
    "allure-commandline": "^2.34.1",
    "allure-cucumberjs": "^3.4.1",
    "cucumberjs-qase-reporter": "^2.2.2",
    "rimraf": "^6.0.1"
  }
}
