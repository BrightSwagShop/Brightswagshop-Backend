{
  "info": {
    "name": "FakeWebShop API - Automated Negative Tests",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "version": "1.0.0"
  },
  "item": [
    {
      "name": "UseCase-Negative",
      "item": [
        {
          "name": "Register duplicate username -> 409",
          "request": {
            "method": "POST",
            "header": [{"key":"Content-Type","value":"application/json"}],
            "url": "{{baseUrl}}/api/users/register",
            "body": {"mode":"raw","raw":"{ \"username\": \"{{existingUser}}\", \"password\": \"P@ssw0rd\" }"}
          },
          "event": [{"listen":"test","script":{"exec":["pm.test('duplicate -> 409', function(){ pm.response.to.have.status(409); });","pm.test('contains duplicate message', function(){ pm.response.to.have.jsonBody(); })"]}}]
        },
        {
          "name": "AzureAd admin denies HeaderAuth -> 401",
          "request": {
            "method": "GET",
            "header": [{"key":"X-User-Id","value":"{{headerAuthUserId}}"},{"key":"X-User-Role","value":"App.Admin"}],
            "url": "{{baseUrl}}/api/admins/admin-only"
          },
          "event": [{"listen":"test","script":{"exec":["pm.test('HeaderAuth cannot access AzureAd endpoint -> 401', function(){ pm.response.to.have.status(401); });"]}}]
        },
        {
          "name": "Payment provider error -> 500",
          "request": {"method":"POST","header":[{"key":"Content-Type","value":"application/json"}],"url":"{{baseUrl}}/api/payments/{{orderFailsOnProviderId}}/checkout","body":{"mode":"raw","raw":"{}"}},
          "event":[{"listen":"test","script":{"exec":["pm.test('payment provider failure -> 500', function(){ pm.response.to.have.status(500); });"]}}]
        },
        {
          "name": "Create order from malformed cart -> 400",
          "request": {"method":"POST","header":[{"key":"Content-Type","value":"application/json"}],"url":"{{baseUrl}}/api/orders/from-cart/{{existingUserId}}","body":{"mode":"raw","raw":"{ \"cart\": \"malformed\" }"}},
          "event":[{"listen":"test","script":{"exec":["pm.test('malformed cart -> 400', function(){ pm.response.to.have.status(400); });"]}}]
        },
        {
          "name": "Webhook malformed JSON -> 400",
          "request": {"method":"POST","header":[{"key":"Content-Type","value":"application/json"},{"key":"Stripe-Signature","value":"t=1234,v1=signature"}],"url":"{{baseUrl}}/api/webhooks/stripe","body":{"mode":"raw","raw":"{ this is : not json }"}},
          "event":[{"listen":"test","script":{"exec":["pm.test('malformed webhook -> 400', function(){ pm.response.to.have.status(400); });"]}}]
        }
      ]
    },
    {
      "name": "State-Negative",
      "item": [
        {
          "name": "Concurrent remove/update -> 404 or 409",
          "request": {"method":"POST","header":[{"key":"Content-Type","value":"application/json"},{"key":"X-Test-Simulate","value":"concurrent-remove-update"}],"url":"{{baseUrl}}/api/shoppingcarts/user/{{u123}}/items","body":{"mode":"raw","raw":"{ \"productId\": \"{{sku1}}\", \"quantity\": 1 }"}},
          "event":[{"listen":"test","script":{"exec":["pm.test('concurrent conflict -> 404 or 409', function(){ pm.expect([404,409]).to.include(pm.response.code); });"]}}]
        },
        {
          "name": "Update quantity to zero -> 400",
          "request": {"method":"PUT","header":[{"key":"Content-Type","value":"application/json"}],"url":"{{baseUrl}}/api/shoppingcarts/user/{{u123}}/quantity","body":{"mode":"raw","raw":"{ \"productId\": \"{{sku2}}\", \"quantity\": 0 }"}},
          "event":[{"listen":"test","script":{"exec":["pm.test('quantity 0 -> 400', function(){ pm.response.to.have.status(400); });"]}}]
        },
        {
          "name": "Remove non-existing item -> 404",
          "request": {"method":"DELETE","header":[{"key":"Content-Type","value":"application/json"}],"url":"{{baseUrl}}/api/shoppingcarts/user/{{u999}}/item","body":{"mode":"raw","raw":"{ \"productId\": \"missingSKU\" }"}},
          "event":[{"listen":"test","script":{"exec":["pm.test('remove missing -> 404', function(){ pm.response.to.have.status(404); });"]}}]
        },
        {
          "name": "Apply discount to nonexistent cart -> 404",
          "request": {"method":"POST","header":[{"key":"Content-Type","value":"application/json"}],"url":"{{baseUrl}}/api/shoppingcarts/{{nonexistentCartId}}/apply-discount","body":{"mode":"raw","raw":"{ \"code\": \"SPRING\" }"}},
          "event":[{"listen":"test","script":{"exec":["pm.test('apply discount nonexistent cart -> 404', function(){ pm.response.to.have.status(404); });"]}}]
        },
        {
          "name": "Discount unmet conditions -> 409",
          "request": {"method":"POST","header":[{"key":"Content-Type","value":"application/json"},{"key":"X-Test-Simulate","value":"discount-unmet"}],"url":"{{baseUrl}}/api/shoppingcarts/{{existingOrderId}}/apply-discount","body":{"mode":"raw","raw":"{ \"code\": \"SPRING\" }"}},
          "event":[{"listen":"test","script":{"exec":["pm.test('discount unmet -> 409', function(){ pm.response.to.have.status(409); });"]}}]
        }
      ]
    },
    {
      "name": "EP-Negative",
      "item": [
