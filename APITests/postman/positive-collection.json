    {
      "name": "Orders-Payments-Positive",
      "item": [
        {
          "name": "Create order from cart -> 201",
          "request": {
            "method": "POST",
            "header": [{"key":"Content-Type","value":"application/json"},{"key":"Authorization","value":"Bearer {{userToken}}"}],
            "url": "{{baseUrl}}/api/orders/from-cart/{{existingUserId}}"
          },
          "event": [{"listen":"test","script":{"exec":["pm.test('order from cart -> 201', function(){ pm.expect([200,201]).to.include(pm.response.code); });"]}}]
        },
        {
          "name": "Checkout order -> 200",
          "request": {
            "method": "POST",
            "header": [{"key":"Content-Type","value":"application/json"},{"key":"Authorization","value":"Bearer {{userToken}}"}],
            "url": "{{baseUrl}}/api/payments/{{existingOrderId}}/checkout",
            "body": {"mode":"raw","raw":"{}"}
          },
          "event": [{"listen":"test","script":{"exec":["pm.test('checkout -> 200', function(){ pm.response.to.have.status(200); });"]}}]
        }
      ]
    }
  ],
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "exec": [
          "(function(){",
          "  const base = pm.environment.get('baseUrl') || 'http://127.0.0.1:5076';",
          "  const existingUser = pm.environment.get('existingUser') || 'existingUser';",
          "  const password = 'P@ssw0rd';",
          "  function finish(){ pm.environment.set('fixtures_ready_positive', 'true'); }",
          "  function login(next){",
          "    pm.sendRequest({",
          "      url: base + '/api/users/login',",
          "      method: 'POST',",
          "      header: {'Content-Type': 'application/json'},",
          "      body: { mode: 'raw', raw: JSON.stringify({ username: existingUser, password: password }) }",
          "    }, function(err, res){",
          "      if(!err && res && res.status === 200){",
          "        try{ const body = res.json(); const token = body.token || body.accessToken || (body.data && body.data.token); if(token) pm.environment.set('userToken', token); } catch(e){}",
          "      }",
          "      next && next();",
          "    });",
          "  }",
          "  function register(next){",
          "    pm.sendRequest({",
          "      url: base + '/api/users/register',",
          "      method: 'POST',",
          "      header: {'Content-Type': 'application/json'},",
          "      body: { mode: 'raw', raw: JSON.stringify({ username: existingUser, password: password }) }",
          "    }, function(err, res){",
          "      if(!err && res && (res.status === 200 || res.status === 201)){",
          "        try{ const body = res.json(); const id = body.id || body.userId || body._id; if(id) pm.environment.set('existingUserId', id); } catch(e){}",
          "      }",
          "      login(next);",
          "    });",
          "  }",
          "  function findProduct(next){",
          "    if(pm.environment.get('existingProductId')){ next && next(); return; }",
          "    pm.sendRequest({ url: base + '/api/products', method: 'GET' }, function(err, res){",
          "      if(!err && res && res.status === 200){",
          "        try{ const body = res.json(); if(Array.isArray(body) && body.length){ const first = body[0]; pm.environment.set('existingProductId', first.id || first._id || first.productId); } } catch(e){}",
          "      }",
          "      next && next();",
          "    });",
          "  }",
          "  function findOrder(next){",
          "    if(pm.environment.get('existingOrderId')){ next && next(); return; }",
          "    const uid = pm.environment.get('existingUserId');",
          "    const token = pm.environment.get('userToken');",
          "    if(!uid || !token){ next && next(); return; }",
          "    pm.sendRequest({",
          "      url: base + '/api/orders/from-cart/' + uid,",
          "      method: 'POST',",
          "      header: { 'Content-Type': 'application/json', 'Authorization': 'Bearer ' + token },",
          "      body: { mode: 'raw', raw: '{}' }",
          "    }, function(err, res){",
          "      if(!err && res && (res.status === 200 || res.status === 201)){ try{ const body = res.json(); pm.environment.set('existingOrderId', body.id || body._id || body.orderId); } catch(e){} }",
          "      next && next();",
          "    });",
          "  }",
          "  function ensureAdmin(next){",
          "    if(pm.environment.get('adminToken')){ next && next(); return; }",
          "    next && next();",
          "  }",
          "  if(pm.environment.get('fixtures_ready_positive') === 'true'){ return; }",
          "  if(!pm.environment.get('existingUserId')){ register(function(){ findProduct(function(){ findOrder(function(){ ensureAdmin(function(){ finish(); }); }); }); }); }",
          "  else if(!pm.environment.get('userToken')){ login(function(){ findProduct(function(){ findOrder(function(){ ensureAdmin(function(){ finish(); }); }); }); }); }",
          "  else { findProduct(function(){ findOrder(function(){ ensureAdmin(function(){ finish(); }); }); }); }",
          "})();"
        ]
      }
    }
  ]
}