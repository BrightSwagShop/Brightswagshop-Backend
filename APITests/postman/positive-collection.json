{
  "info": {
    "name": "FakeWebShop API - Automated Positive Tests",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "version": "1.0.0"
  },
  "item": [
    {
      "name": "UseCase-Positive",
      "item": [
        {
          "name": "Register a new user -> 200",
          "request": {
            "method": "POST",
            "header": [{"key":"Content-Type","value":"application/json"}],
            "url": "{{baseUrl}}/api/users/register",
            "body": {"mode":"raw","raw":"{ \"username\": \"positiveUser\", \"password\": \"P@ssw0rd\" }"}
          },
          "event": [{"listen":"test","script":{"exec":["pm.test('register -> 200', function(){ pm.expect([200,201]).to.include(pm.response.code); });"]}}]
        },
        {
          "name": "Login existing user -> 200",
          "request": {
            "method": "POST",
            "header": [{"key":"Content-Type","value":"application/json"}],
            "url": "{{baseUrl}}/api/users/login",
            "body": {"mode":"raw","raw":"{ \"username\": \"{{existingUser}}\", \"password\": \"P@ssw0rd\" }"}
          },
          "event": [{"listen":"test","script":{"exec":["pm.test('login -> 200', function(){ pm.response.to.have.status(200); });","pm.test('login returns token', function(){ pm.expect(pm.response.json()).to.be.an('object'); });"]}}]
        },
        {
          "name": "Fetch own profile -> 200",
          "request": {
            "method": "GET",
            "header": [{"key":"Authorization","value":"Bearer {{userToken}}"}],
            "url": "{{baseUrl}}/api/users/me"
          },
          "event": [{"listen":"test","script":{"exec":["pm.test('me -> 200', function(){ pm.response.to.have.status(200); });"]}}]
        }
      ]
    },
    {
      "name": "Catalog-Positive",
      "item": [
        {
          "name": "List products -> 200",
          "request": {"method":"GET","url":"{{baseUrl}}/api/products"},
          "event": [{"listen":"test","script":{"exec":["pm.test('products -> 200', function(){ pm.response.to.have.status(200); });","pm.test('products is array', function(){ pm.expect(pm.response.json()).to.be.an('array'); });"]}}]
        },
        {
          "name": "Get existing product -> 200",
          "request": {"method":"GET","url":"{{baseUrl}}/api/products/{{existingProductId}}"},
          "event": [{"listen":"test","script":{"exec":["pm.test('product -> 200', function(){ pm.response.to.have.status(200); });"]}}]
        },
        {
          "name": "List categories -> 200",
          "request": {"method":"GET","url":"{{baseUrl}}/api/categories"},
          "event": [{"listen":"test","script":{"exec":["pm.test('categories -> 200', function(){ pm.response.to.have.status(200); });"]}}]
        },
        {
          "name": "List product types -> 200",
          "request": {"method":"GET","url":"{{baseUrl}}/api/producttypes"},
          "event": [{"listen":"test","script":{"exec":["pm.test('product types -> 200', function(){ pm.response.to.have.status(200); });"]}}]
        }
      ]
    },
    {
      "name": "Admin-Positive",
      "item": [
        {
          "name": "Create product -> 201",
          "request": {
            "method": "POST",
            "header": [{"key":"Content-Type","value":"application/json"},{"key":"Authorization","value":"Bearer {{adminToken}}"}],
            "url": "{{baseUrl}}/api/products",
            "body": {"mode":"raw","raw":"{ \"title\": \"positive product\", \"price\": 10, \"productType\": \"tshirt\" }"}
          },
          "event": [{"listen":"test","script":{"exec":["pm.test('create product -> 201', function(){ pm.expect([200,201]).to.include(pm.response.code); });"]}}]
        },
        {
          "name": "Create discount -> 201",
          "request": {
            "method": "POST",
            "header": [{"key":"Content-Type","value":"application/json"},{"key":"Authorization","value":"Bearer {{adminToken}}"}],
            "url": "{{baseUrl}}/api/discounts",
            "body": {"mode":"raw","raw":"{ \"code\": \"WELCOME10\", \"startDate\": \"2025-01-01\", \"endDate\": \"2026-12-31\" }"}
          },
          "event": [{"listen":"test","script":{"exec":["pm.test('create discount -> 201', function(){ pm.expect([200,201]).to.include(pm.response.code); });"]}}]
